PORT=4317
DASHBOARD_TOKEN=change-this-to-a-long-random-secret
UPLOAD_RETENTION_HOURS=24

# Instagram Business publishing.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# TikTok OAuth for inbox upload. Redirect URI must match TikTok Developer Portal.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://YOUR_GITHUB_USER.github.io/YOUR_REPO/oauth/tiktok/callback.html
TIKTOK_SCOPES=video.upload

# Free public media storage for Instagram.
# Repo must be public because Instagram needs unauthenticated HTTPS access.
GITHUB_STORAGE_TOKEN=
GITHUB_STORAGE_OWNER=
GITHUB_STORAGE_REPO=
GITHUB_STORAGE_BRANCH=main
GITHUB_STORAGE_FOLDER=social-publisher-dashboard
GITHUB_STORAGE_PUBLIC_BASE_URL=

# Optional AI caption generation. OpenAI-compatible endpoint.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
